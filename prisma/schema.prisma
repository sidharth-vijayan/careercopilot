generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String        @id @default(uuid())
  email            String        @unique
  name             String?
  avatarUrl        String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  resumes          Resume[]
  analyses         JobAnalysis[]
  applications     Application[]
  vaultItems       VaultItem[]
  tailoredResumes  TailoredResume[]
}

model Resume {
  id               String        @id @default(uuid())
  userId           String
  user             User          @relation(fields: [userId], references: [id])
  originalName     String
  fileUrl          String
  parsedText       String        @db.Text
  isDefault        Boolean       @default(false)
  createdAt        DateTime      @default(now())
  analyses         JobAnalysis[]
}

model JobAnalysis {
  id               String        @id @default(uuid())
  userId           String
  user             User          @relation(fields: [userId], references: [id])
  resumeId         String
  resume           Resume        @relation(fields: [resumeId], references: [id])
  jobTitle         String
  company          String
  jobDescription   String        @db.Text
  matchScore       Int
  analysisData     Json          // Stores missing skills, heatmaps, ATS warnings, etc.
  createdAt        DateTime      @default(now())
}

model Application {
  id               String        @id @default(uuid())
  userId           String
  user             User          @relation(fields: [userId], references: [id])
  jobTitle         String
  company          String
  status           String        // Enum: applied, interview, offer, rejected, saved
  matchScore       Int?
  jobDescription   String?       @db.Text
  appliedAt        DateTime      @default(now())
  notes            String?       @db.Text
}

model VaultItem {
  id               String        @id @default(uuid())
  userId           String
  user             User          @relation(fields: [userId], references: [id])
  type             String        // "experience" | "project" | "skill"
  title            String        // e.g. "Senior Software Engineer at TechCorp"
  bulletPoints     Json          // Stores array of strings: string[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}

model TailoredResume {
  id               String        @id @default(uuid())
  userId           String
  user             User          @relation(fields: [userId], references: [id])
  jobTitle         String
  company          String
  tailoredData     Json          // Stores tailored structure: experiences, projects, skills list
  createdAt        DateTime      @default(now())
}
